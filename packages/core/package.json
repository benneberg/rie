{
  "name": "@archlens/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./parsers": {
      "import": "./dist/parsers/index.js",
      "types": "./dist/parsers/index.d.ts"
    },
    "./cag": {
      "import": "./dist/graph/cag-schema.js",
      "types": "./dist/graph/cag-schema.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.21.1",
    "tree-sitter-java": "^0.21.1",
    "tree-sitter-python": "^0.21.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
